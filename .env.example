# Production environment variables for the fiestas-app stack.
# Copy to .env and replace every `change-me` value before deploying.
# All keys marked REQUIRED must be present — the backend refuses to boot
# in production without them.

# --- MongoDB ---
MONGO_ROOT_USERNAME=fiestas_admin
MONGO_ROOT_PASSWORD=change-me-strong-mongo-password
MONGO_DATABASE=fiestas_db

# --- Backend ---
# REQUIRED: signing secret for JWTs. Generate with `openssl rand -hex 32`.
JWT_SECRET=
JWT_EXPIRE=7d

# REQUIRED in production: comma-separated origins the API + socket.io will accept.
# Example: https://miyo.edvardks.com,https://www.miyo.edvardks.com
CORS_ALLOWED_ORIGINS=

# Optional legacy fallback (single origin) — only used when CORS_ALLOWED_ORIGINS is empty.
APP_URL=

# Optional rate limit overrides (defaults: 100 req / 15 min per IP).
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# --- Email (transactional notifications) ---
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USER=noreply@example.com
EMAIL_PASS=change-me-smtp-password

# --- Runtime ---
NODE_ENV=production
